{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "npx tsx server/index.ts",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
